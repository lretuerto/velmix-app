APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# En entornos no locales:
# APP_ENV=production
# APP_DEBUG=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
# LOG_STACK=single,stderr_json
# En produccion se recomienda incluir al menos stderr_json o daily_json
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=velmix
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# VELMIX_ALERT_BILLING_DAYS=7
# VELMIX_ALERT_FINANCE_DAYS_AHEAD=7
# VELMIX_ALERT_PRIORITY_LIMIT=5
# VELMIX_ALERT_FAILURE_LIMIT=5
# VELMIX_ALERT_STALE_FOLLOW_UP_DAYS=3
# VELMIX_ALERT_NOTIFY_CHANNELS=log
# VELMIX_ALERT_NOTIFY_MIN_SEVERITY=warning
# VELMIX_ALERT_NOTIFY_COOLDOWN_MINUTES=30
# VELMIX_ALERT_NOTIFY_LOG_CHANNEL=daily_json
# VELMIX_ALERT_WEBHOOK_URL=
# VELMIX_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
# VELMIX_ALERT_SLACK_WEBHOOK_URL=
# VELMIX_ALERT_SLACK_CHANNEL=#ops-alerts
# VELMIX_ALERT_SLACK_USERNAME=VELMiX Alerts
# VELMIX_ALERT_SLACK_ICON_EMOJI=:rotating_light:
# VELMIX_SCHEDULER_TIMEZONE=America/Lima
# VELMIX_SCHEDULER_ON_ONE_SERVER=true
# Requiere CACHE_STORE compartido entre nodos, por ejemplo database o redis
# VELMIX_APP_ROOT=/var/www/velmix
# VELMIX_APP_PATH=/var/www/velmix/current
# VELMIX_RELEASES_PATH=/var/www/velmix/releases
# VELMIX_SHARED_PATH=/var/www/velmix/shared
# VELMIX_CURRENT_LINK=/var/www/velmix/current
# VELMIX_PREVIOUS_LINK=/var/www/velmix/previous
# VELMIX_ENV_FILE=/var/www/velmix/shared/.env
# VELMIX_SYSTEMD_TARGET=velmix-backend.target
# VELMIX_SYSTEMD_SCHEDULER_SERVICE=velmix-scheduler.service
# VELMIX_SYSTEMD_QUEUE_SERVICE=velmix-queue-worker.service
# VELMIX_SYSTEMD_QUEUE_RESTART_SERVICE=velmix-queue-restart.service
# VELMIX_SCHEDULER_DISPATCH_LIMIT=20
# VELMIX_SCHEDULER_DISPATCH_EVERY_MINUTES=1
# VELMIX_SCHEDULER_DISPATCH_OVERLAP_MINUTES=10
# VELMIX_SCHEDULER_RECONCILE_LIMIT=20
# VELMIX_SCHEDULER_RECONCILE_EVERY_MINUTES=5
# VELMIX_SCHEDULER_RECONCILE_OVERLAP_MINUTES=15
# VELMIX_SCHEDULER_ALERTS_EVERY_MINUTES=5
# VELMIX_SCHEDULER_ALERTS_OVERLAP_MINUTES=10
# VELMIX_SCHEDULER_ALERT_DISPATCH_EVERY_MINUTES=5
# VELMIX_SCHEDULER_ALERT_DISPATCH_OVERLAP_MINUTES=10
# VELMIX_SCHEDULER_PRUNE_AT=03:15
# VELMIX_SCHEDULER_PRUNE_OVERLAP_MINUTES=180
# VELMIX_RETENTION_IDEMPOTENCY_DAYS=14
# VELMIX_RETENTION_OUTBOX_ATTEMPTS_DAYS=180
# VELMIX_RETENTION_TEAM_INVITATIONS_DAYS=90
# VELMIX_RETENTION_CONTROL_TOWER_SNAPSHOTS_DAYS=90

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
