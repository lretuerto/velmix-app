# Core runtime
APP_ENV=production
APP_DEBUG=false
APP_URL=https://velmix.example.com
APP_TIMEZONE=America/Lima

# Logging
LOG_CHANNEL=stack
LOG_STACK=daily_json,stderr_json
LOG_LEVEL=info

# Persistence
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=velmix
DB_USERNAME=velmix
DB_PASSWORD=change-me

# Platform services
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# Release layout
VELMIX_APP_ROOT=/var/www/velmix
VELMIX_APP_PATH=/var/www/velmix/current
VELMIX_RELEASES_PATH=/var/www/velmix/releases
VELMIX_SHARED_PATH=/var/www/velmix/shared
VELMIX_CURRENT_LINK=/var/www/velmix/current
VELMIX_PREVIOUS_LINK=/var/www/velmix/previous
VELMIX_ENV_FILE=/var/www/velmix/shared/.env

# Binaries
VELMIX_PHP_BIN=/usr/bin/php
VELMIX_COMPOSER_BIN=/usr/bin/composer

# Process topology
VELMIX_SYSTEMD_TARGET=velmix-backend.target
VELMIX_SYSTEMD_SCHEDULER_SERVICE=velmix-scheduler.service
VELMIX_SYSTEMD_QUEUE_SERVICE=velmix-queue-worker.service
VELMIX_SYSTEMD_QUEUE_RESTART_SERVICE=velmix-queue-restart.service

# Scheduler safety
VELMIX_SCHEDULER_ON_ONE_SERVER=true
VELMIX_SCHEDULER_TIMEZONE=America/Lima

# Queue worker defaults
VELMIX_QUEUE_NAME=default
VELMIX_QUEUE_SLEEP=1
VELMIX_QUEUE_TRIES=1
VELMIX_QUEUE_TIMEOUT=120
VELMIX_QUEUE_MAX_TIME=3600

# Backup and restore posture
VELMIX_BACKUP_ENABLED=true
VELMIX_BACKUP_DRIVER=external
VELMIX_BACKUP_STORAGE_PATH=/var/www/velmix/shared/backups
VELMIX_BACKUP_HISTORY_PATH=/var/www/velmix/shared/backups/history
VELMIX_BACKUP_MANIFEST_FILENAME=latest-backup.json
VELMIX_BACKUP_MAX_AGE_HOURS=26
VELMIX_BACKUP_RETENTION_DAYS=14
VELMIX_BACKUP_REQUIRE_ENCRYPTION=true
VELMIX_BACKUP_ENCRYPTION_PASSPHRASE=change-me
VELMIX_RESTORE_DRILL_PATH=/var/www/velmix/shared/restore-drills
VELMIX_RESTORE_DRILL_MAX_AGE_DAYS=30
