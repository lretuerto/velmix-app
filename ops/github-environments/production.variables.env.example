# Recommended GitHub environment variables for the remote topology
VELMIX_REMOTE_TOPOLOGY_ID=production-primary-node
VELMIX_REMOTE_TOPOLOGY_MODE=isolated
VELMIX_REMOTE_PORT=22
VELMIX_REMOTE_APP_ROOT=/var/www/velmix
VELMIX_REMOTE_RELEASES_PATH=/var/www/velmix/releases
VELMIX_REMOTE_SHARED_PATH=/var/www/velmix/shared
VELMIX_REMOTE_ENV_FILE=/var/www/velmix/shared/.env
VELMIX_REMOTE_TMP_PATH=/tmp/velmix-deploy
VELMIX_REMOTE_USE_SYSTEMD=true
VELMIX_REMOTE_INSTALL_UNITS=false
VELMIX_REMOTE_PHP_BIN=php
VELMIX_REMOTE_COMPOSER_BIN=composer
VELMIX_REMOTE_SYSTEMD_TARGET=velmix-backend.target
VELMIX_REMOTE_QUEUE_RESTART_SERVICE=velmix-queue-restart.service
